{
  "app": {
    "name": "ElderAI Survey Platform",
    "name_zh": "适老化智能问卷与AI数据分析平台",
    "version": "1.0.0",
    "language": "zh-CN",
    "debug": false
  },
  "paths": {
    "questionnaire": "survey/questionnaire.json",
    "answers_csv": "survey/answers.csv",
    "autosave": "survey/autosave.json",
    "database": "database/survey.db",
    "exports": "exports",
    "backup": "backup",
    "logs": "logs"
  },
  "accessibility": {
    "font_sizes": [24, 36, 48, 60, 72],
    "default_font_size": 48,
    "default_font_bold": true,
    "contrast_themes": ["white_black", "black_white", "blue_yellow"],
    "default_theme": "white_black",
    "button_min_height": 80,
    "button_min_width": 300,
    "button_spacing": 20,
    "timeout_seconds": 60,
    "auto_reread": true,
    "anti_misclick_ms": 400,
    "answer_mode": "standard",
    "interviewer_name": "小助手"
  },
  "speech": {
    "enabled": true,
    "offline_engine": "pyttsx3",
    "offline_asr": "vosk",
    "online_asr": "whisper",
    "vosk_model_path": "models/vosk-model-small-cn",
    "tts_rate": 150,
    "tts_volume": 1.0
  },
  "ai": {
    "mode": "auto",
    "active_provider": "deepseek",
    "timeout_seconds": 30,
    "fallback_to_offline": true,
    "min_insights": 10,
    "providers": {
      "openai": {
        "enabled": false,
        "api_key": "",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o-mini"
      },
      "deepseek": {
        "enabled": false,
        "api_key": "",
        "base_url": "https://api.deepseek.com/v1",
        "model": "deepseek-chat"
      },
      "qwen": {
        "enabled": false,
        "api_key": "",
        "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "model": "qwen-plus"
      },
      "openrouter": {
        "enabled": false,
        "api_key": "",
        "base_url": "https://openrouter.ai/api/v1",
        "model": "anthropic/claude-3.5-sonnet"
      }
    }
  },
  "dashboard": {
    "theme": "tech_blue",
    "refresh_interval_seconds": 5,
    "carousel_interval_seconds": 10,
    "carousel_pages": ["overview", "charts", "trends", "ai", "report"],
    "fullscreen": true
  },
  "export": {
    "formats": ["excel", "pdf", "word"],
    "company_name": "Shenshen Yang & Yizhi Wang课题组",
    "report_title": "适老化智能问卷调查分析报告"
  },
  "about": {
    "author": "Jiacheng Zheng",
    "credit": "使用 Claude Code 辅助开发",
    "contact_label": "联系我",
    "contact_url": "https://karcen.github.io/zhengjiacheng.github.io/"
  }
}
